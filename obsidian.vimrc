" .obsidian.vimrc
" a subset of my .vimrc settings specifically for Obsidian

set tabstop=4
set softtabstop=4
set expandtab
set shiftwidth=4

" move vertically by visual line

nmap j gj
nmap k gk

vmap j gj
vmap k gk

" use H and L to go to beginning and end of a line
nmap H ^
nmap L $

vmap H ^
vmap L $
