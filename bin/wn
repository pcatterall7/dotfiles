#!/bin/zsh

# Create or open my weekly work note
year=$(date +%Y)
week=$(date +%V)
filename="${year}-W${week}.md"
directory="${HOME}/notes/aiq/01-daily/15-5"

filepath="${directory}/${filename}"

if [ -f "$filepath" ]; then
    echo "Opening existing file: $filename"
else
    echo "Creating new file: $filename"
    echo "# $(date -v -Mon +"%d %b %Y") - $(date -v +Fri +"%d %b %Y")\n\n
## Priorities\n\n
## What I actually did" \
    >> "$filepath"
fi

code "$filepath"