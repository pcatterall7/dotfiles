#!/bin/bash

# Updated: 2024-01-31
# Takes a markdown file path in the clipboard and tries to convert
# the file to html. Then, open the file.

# directory with the github or google docs css files
CSS_DIR="${HOME}/.dotfiles/css"

get_css_path () {
  case $1 in 
    gh)
      css_path="${CSS_DIR}/github.css" ;;
    gd)
      css_path="${CSS_DIR}/gdocs.css" ;;
    "")
      echo "No css value provided. Defaulting to github.css"
      css_path="${CSS_DIR}/github.css"
      ;;
    *)
      echo "Error: css value must be gh (github) or gd (google docs)." >&2
	    exit 1
      ;;
  esac
}

OPTIND=1
css_file=""

while getopts "c:h" opt; do
	case $opt in
		h)
      # TODO: implement help menu
      show_help
      exit 0
      ;;
    c)
      css_file=$OPTARG
      ;;
    *)
      show_help >&2
      exit 1
      ;;
  esac
done

shift "$((OPTIND - 1))"

# set full_path either from the first positional argument or stdin
if [[ $# -gt 0 ]]; then
  full_path="$1"
else
  read full_path
fi

get_css_path "${css_file}"
output_path="${TMPDIR}out.html"

# if the filepath is valid, run pandoc and open the html output
if [[ -f "${full_path}" ]]; then
	pandoc -c ${css_path} -f markdown -o "${output_path}" -s "${full_path}"  --quiet
	open "${output_path}"
else
  # If it doesn't, print an error message
  echo "Error: ${full_path} does not exist." >&2
  exit 1
fi
