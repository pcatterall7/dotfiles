#!/bin/bash

# Updated: 2022-12-21
# Takes a markdown file path in the clipboard and tries to convert
# the file to html. Then, open the file. Useful for previewing docs
# generated in Obsidian.

CSS_DIR="${HOME}/.dotfiles/css"

show_help() {
    echo "Usage: $0 [-c css_style] [file_path]"
    echo
    echo "Converts a markdown file to HTML format using a specified CSS style."
    echo
    echo "Options:"
    echo "  -h          Show this help message."
    echo "  -c css_style  Specify the css file to use. Options are 'gh' for GitHub style or 'gd' for Google Docs style."
    echo "                If not specified, defaults to GitHub style."
    echo
    echo "Argument:"
    echo "  file_path   Path to the markdown file to convert. If not specified, reads from stdin."
    echo
    echo "Example:"
    echo "  $0 -c gh my_markdown_file.md"
    echo "  This will convert 'my_markdown_file.md' to HTML using GitHub style css."
}

get_css_path () {
  case $1 in
    gh)
      css_path="${CSS_DIR}/github.css" ;;
    gd)
      css_path="${CSS_DIR}/gdocs.css" ;;
    "")
      echo "No css value provided. Defaulting to github.css"
      css_path="${CSS_DIR}/github.css"
      ;;
    *)
      echo "Error: css value must be gh (github) or gd (google docs)." >&2
	    exit 1
      ;;
  esac
}

OPTIND=1
css_file=""
# echo "[DEBUG] @: $@"
# echo "[DEBUG] #: $#"

while getopts "c:h" opt; do
	case $opt in
		h)
      show_help
      exit 0
      ;;
    c)
      css_file=$OPTARG
      ;;
    *)
      show_help >&2
      exit 1
      ;;
  esac
done

shift "$((OPTIND - 1))" # Discard the options and sentinel --

# set full_path either from the first positional argument or stdin
if [[ $# -gt 0 ]]; then
  full_path="$1"
else
  read full_path
fi

get_css_path "${css_file}"
output_path="${TMPDIR}out.html"

# if the filepath is valid, run pandoc and open the html output
if [[ -f "${full_path}" ]]; then
	pandoc -c ${css_path} -f markdown -o "${output_path}" -s "${full_path}"  --quiet
	open "${output_path}"
else
  # If it doesn't, print an error message
  echo "Error: ${full_path} does not exist." >&2
  exit 1
fi
# TODO: take path as input or file itself?
